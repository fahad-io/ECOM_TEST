# Server
PORT=8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/marl
# Only needed for a mongodb+srv:// Atlas URI when your machine's DNS refuses SRV
# lookups (querySrv ECONNREFUSED). Point Node at a resolver that answers SRV:
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Stripe (test mode). Leave blank to use the clearly-marked mock payment fallback.
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
