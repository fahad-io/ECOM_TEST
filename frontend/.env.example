# MARL frontend environment
# Copy to .env.local and fill in. .env.local is gitignored.

# Backend API base path (includes /api).
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Stripe publishable key (test mode). Used by the checkout payment element.
# Leave blank to fall back to mock checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
